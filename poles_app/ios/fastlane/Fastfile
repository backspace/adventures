default_platform(:ios)

# Load secrets if present. Real values live in .env.fastlane (gitignored);
# .env.fastlane.example documents what should be set.
env_file = File.expand_path(".env.fastlane", __dir__)
if File.exist?(env_file)
  File.foreach(env_file) do |line|
    next if line.strip.empty? || line.start_with?("#")
    key, value = line.strip.split("=", 2)
    ENV[key] ||= value if key && value
  end
end

ALPHA_API_ROOT      = "https://poles-staging.chromatin.ca"
PRODUCTION_API_ROOT = "https://poles.chromatin.ca"
FLUTTER_PROJECT_DIR = File.expand_path("../..", __dir__)
IPA_DIR             = File.join(FLUTTER_PROJECT_DIR, "build/ios/ipa")

def find_ipa
  ipa = Dir.glob(File.join(IPA_DIR, "*.ipa")).max_by { |f| File.mtime(f) }
  UI.user_error!("No .ipa found in #{IPA_DIR} — did flutter build ipa succeed?") if ipa.nil?
  ipa
end

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.expand_path(ENV.fetch("ASC_KEY_FILEPATH"))
  )
end

def next_build_number
  commit_count = `git rev-list --count HEAD`.strip.to_i
  latest = latest_testflight_build_number(
    api_key: asc_api_key,
    app_identifier: "ca.chromatin.poles",
    initial_build_number: 0
  )
  [commit_count, latest + 1].max
end

def flutter_build_ipa(flavor:, api_root:, sentry_dsn:)
  build_number = next_build_number
  Dir.chdir(FLUTTER_PROJECT_DIR) do
    sh(
      "flutter", "build", "ipa",
      "--build-number=#{build_number}",
      "--export-options-plist=ios/ExportOptions.plist",
      "--dart-define=FLAVOR_NAME=#{flavor}",
      "--dart-define=API_ROOT=#{api_root}",
      "--dart-define=SENTRY_DSN=#{sentry_dsn}"
    )
  end
end

platform :ios do
  desc "Build with alpha flavor (staging API) and upload to TestFlight"
  lane :alpha do
    flutter_build_ipa(
      flavor: "alpha",
      api_root: ALPHA_API_ROOT,
      sentry_dsn: ENV.fetch("SENTRY_DSN", "")
    )
    upload_to_testflight(
      api_key: asc_api_key,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build with production flavor (production API) and upload to TestFlight"
  lane :production do
    flutter_build_ipa(
      flavor: "production",
      api_root: PRODUCTION_API_ROOT,
      sentry_dsn: ENV.fetch("SENTRY_DSN", "")
    )
    upload_to_testflight(
      api_key: asc_api_key,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true
    )
  end
end

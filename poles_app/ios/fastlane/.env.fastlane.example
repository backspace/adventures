# Copy to .env.fastlane (gitignored) and fill in real values.

# App Store Connect API key — App Store Connect → Users and Access → Integrations
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_FILEPATH=~/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8

# Apple Developer team ID — Apple Developer portal, top right
APPLE_TEAM_ID=

# Sentry DSN — single Flutter project; alpha vs production is differentiated
# by the environment tag set in main.dart, not by the DSN. Optional.
SENTRY_DSN=

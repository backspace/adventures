# Copy to .env.fastlane (gitignored) and fill in real values.

# Path to the Play Console service account JSON. Generated in Google Cloud
# Console (IAM → Service accounts → keys → JSON), then granted "Release
# manager" on the Poles app in Play Console → Users and permissions.
# Save the file outside this repo (e.g., ~/.playconsole/poles.json) and
# never commit it.
PLAY_JSON_KEY_PATH=~/.playconsole/poles.json

# Sentry DSN — same single DSN used for iOS. The environment tag in
# main.dart (`options.environment = F.name`) keeps alpha and production
# events separate in Sentry's UI. Optional.
SENTRY_DSN=
